# ── Database (Aiven Cloud) ──────────────────────────────────
DB_HOST=your-aiven-host.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=your_password
DB_NAME=defaultdb
DB_PORT=12272
DB_SSL_REJECT_UNAUTHORIZED=false
DB_CONNECTION_LIMIT=10

# ── Twilio SMS ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Groq AI ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key

# ── Geoapify ─────────────────────────────────────────────────
GEOAPIFY_KEY=your_geoapify_key

# ── Blockchain (leave blank on Railway — app works without it) ─
REQUEST_CONTRACT_ADDRESS=
PRESCRIPTION_CONTRACT_ADDRESS=
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=

# ── API Gateway / Auth ───────────────────────────────────────
JWT_SECRET=your_jwt_secret_key
INTERNAL_API_KEY=pharma_internal_2025

# ── Redis (optional — app works without it, caching disabled gracefully) ──
REDIS_URL=redis://localhost:6379

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3002
