# Blockchain Configuration
# Copy this file to .env and fill in your deployed contract addresses

# ============================================
# SEPOLIA TESTNET CONFIGURATION
# ============================================

# Your deployed contract addresses from Remix IDE
# Get these after deploying in Remix - they look like: 0x5FbDB2315678afecb367f032d93F642f64180aa3
REQUEST_CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS
PRESCRIPTION_CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS

# Sepolia RPC URL (public node - no API key needed)
BLOCKCHAIN_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Your MetaMask private key (TESTNET WALLET ONLY!)
# Get this from MetaMask: Account Details → Show Private Key
# ⚠️ NEVER use your real mainnet wallet key here!
BLOCKCHAIN_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# ============================================
# ALTERNATIVE RPC PROVIDERS (if needed)
# ============================================
# If the default RPC is slow, you can use:
# - Infura: https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# - Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# - Ankr: https://rpc.ankr.com/eth_sepolia

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# □ MetaMask installed
# □ Switched to Sepolia network
# □ Got testnet ETH from faucet
# □ Deployed EmergencyRequestLedger in Remix
# □ Copied REQUEST_CONTRACT_ADDRESS above
# □ Deployed PrescriptionLedger in Remix
# □ Copied PRESCRIPTION_CONTRACT_ADDRESS above
# □ Copied your private key from MetaMask
# □ Saved this file as .env (remove .example)
# □ Restarted your Next.js server
